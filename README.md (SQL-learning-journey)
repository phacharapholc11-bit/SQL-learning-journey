   Question 3: Annual Sales Trend & Growth
SELECT 
    strftime('%Y', "Order Date") AS Sales_Year, -- (Note) We have daily and monthly 'Order Date' database, so we want to look at the growth trends of the E-commerce business (Year)
    SUM(Sales) AS Total_Sales,                
    COUNT("Order Date") AS Total_Orders,                 
    ROUND(SUM(Profit), 2) AS Total_Profit      
FROM ecommerce_sales_data
GROUP BY Sales_Year                           
ORDER BY Sales_Year ASC;     

