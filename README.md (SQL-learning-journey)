   Question 4: Low-Profitability Category Detection
/*Categories with high sales volume but low average profit per order*/

SELECT
 Category,
 round(Sales,2) as Total_Sales,
 ROUND(SUM(Profit) /sum(Quantity), 2) AS Profit_Per_Unit
FROM ecommerce_sales_data
GROUP by Category
HAVING profit_Per_Unit < 500
Order by Total_Sales DESC;

