   Question 2: Most Profitable Products
/*Top 5 Most Profitablr Products (per_unit)*/
SELECT 
   "Product Name",
    ROUND(SUM(Profit) /sum(Quantity), 2) AS Profit_Per_Unit
FROM ecommerce_sales_data
GROUP by "Product Name"
LIMIT 5;

